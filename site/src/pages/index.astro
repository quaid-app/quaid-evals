---
import BaseLayout from '../layouts/BaseLayout.astro';
import reportData from '../data/report.json';

const { latest, history, reference, total_runs, dab_v2 } = reportData;
const gbrain = reference.gbrain;

const latestDab = latest?.benchmarks?.dab;
const latestGbrain = latest?.benchmarks?.gbrain_evals;
const latestVersion = latest?.version ?? 'No runs yet';
const latestDate = latest?.date ?? '';

const chartVersions = history.map((run) => run.version);
const dabScores = history.map((run) => run.benchmarks?.dab?.pct ?? null);
const rAt5Scores = history.map((run) => run.benchmarks?.gbrain_evals?.r_at_5 ?? null);
const p5Scores = history.map((run) => run.benchmarks?.gbrain_evals?.p_at_5 ?? null);

const dabV2History = dab_v2?.all_runs ?? [];
const dabV2Quaid = dabV2History
  .filter((run) => run.system === 'quaid')
  .sort((left, right) =>
    String(left.version ?? '').localeCompare(String(right.version ?? ''), undefined, { numeric: true })
  );
const dabV2LatestQuaid = dabV2Quaid[dabV2Quaid.length - 1];
const dabV2QuaidSections = dabV2LatestQuaid?.sections;

const dabV2Systems = {
  quaid: dabV2LatestQuaid,
  gbrain: dabV2History.find((run) => run.system === 'gbrain'),
  qmd: dabV2History.find((run) => run.system === 'qmd'),
};

const scoreTone = (value, strong, okay) => {
  if (value >= strong) return 'is-success';
  if (value >= okay) return 'is-warning';
  return 'is-alert';
};
---

<BaseLayout
  title="Results | Quaid Evals"
  description="benchmark.quaid.app results for Quaid's release gate and competitive benchmark."
>
  <script
    slot="head"
    is:inline
    src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"
  ></script>

  <div class="page">
    <section class="hero">
      <div class="page-kicker">Results</div>
      <h1>benchmark.quaid.app</h1>
      <p>
        Release-gate results for DAB v1 and competitive tracking for DAB v2. {total_runs} published runs so far.
      </p>
    </section>

    <section class="panel">
      <div class="section-heading">
        <h2>DAB v1</h2>
        <p>Regression gate status for the latest Quaid release.</p>
      </div>
      <div class="card-grid">
        <div class="panel metric-card">
          <div class="metric-label">DAB Score</div>
          <div class="metric-value is-bronze">{latestDab ? `${latestDab.total}/${latestDab.max}` : 'n/a'}</div>
          <div class="metric-sub">{latestDab ? `${latestDab.pct}%` : 'No runs yet'}</div>
        </div>
        <div class="panel metric-card">
          <div class="metric-label">P@5</div>
          <div class="metric-value">{latestGbrain?.p_at_5 != null ? `${latestGbrain.p_at_5}%` : 'n/a'}</div>
          <div class="metric-sub">GBrain reference: {gbrain.gbrain_evals.p_at_5}%</div>
        </div>
        <div class="panel metric-card">
          <div class="metric-label">R@5</div>
          <div class="metric-value">{latestGbrain?.r_at_5 != null ? `${latestGbrain.r_at_5}%` : 'n/a'}</div>
          <div class="metric-sub">GBrain reference: {gbrain.gbrain_evals.r_at_5}%</div>
        </div>
        <div class="panel metric-card">
          <div class="metric-label">Latest Release</div>
          <div class="metric-value">{latestVersion}</div>
          <div class="metric-sub">{latestDate || 'No date available'}</div>
        </div>
      </div>
    </section>

    {history.length > 1 && (
      <section class="chart-grid">
        <div class="panel chart-card">
          <div class="chart-title">DAB v1 score history</div>
          <canvas id="dabHistory" height="150"></canvas>
        </div>
        <div class="panel chart-card">
          <div class="chart-title">MSMARCO P@5 and R@5</div>
          <canvas id="msmarcoHistory" height="150"></canvas>
        </div>
      </section>
    )}

    <section class="panel">
      <div class="section-heading">
        <h2>DAB v2</h2>
        <p>Measured competitive benchmark snapshots. Quaid uses the latest measured Quaid run.</p>
      </div>
      <div class="card-grid">
        <div class="panel metric-card">
          <div class="metric-label">Quaid</div>
          <div class={`metric-value ${scoreTone(dabV2LatestQuaid?.pct ?? 0, 50, 30)}`}>
            {dabV2LatestQuaid ? `${dabV2LatestQuaid.total}/${dabV2LatestQuaid.max}` : 'n/a'}
          </div>
          <div class="metric-sub">
            {dabV2LatestQuaid ? `${dabV2LatestQuaid.pct}% - v${dabV2LatestQuaid.version}` : 'No Quaid run found'}
          </div>
        </div>
        <div class="panel metric-card">
          <div class="metric-label">Infrastructure</div>
          <div class={`metric-value ${scoreTone(dabV2QuaidSections?.s1_infrastructure?.score ?? 0, 30, 20)}`}>
            {dabV2QuaidSections?.s1_infrastructure?.score ?? 'n/a'}
          </div>
          <div class="metric-sub">out of {dabV2QuaidSections?.s1_infrastructure?.max ?? 40}</div>
        </div>
        <div class="panel metric-card">
          <div class={`metric-label`}>Retrieval</div>
          <div class={`metric-value ${scoreTone(dabV2QuaidSections?.s2_realworld_retrieval?.score ?? 0, 70, 45)}`}>
            {dabV2QuaidSections?.s2_realworld_retrieval?.score ?? 'n/a'}
          </div>
          <div class="metric-sub">out of {dabV2QuaidSections?.s2_realworld_retrieval?.max ?? 100}</div>
        </div>
        <div class="panel metric-card">
          <div class="metric-label">Intelligence</div>
          <div class={`metric-value ${scoreTone(dabV2QuaidSections?.s5_agent_intelligence?.score ?? 0, 40, 20)}`}>
            {dabV2QuaidSections?.s5_agent_intelligence?.score ?? 'n/a'}
          </div>
          <div class="metric-sub">out of {dabV2QuaidSections?.s5_agent_intelligence?.max ?? 80}</div>
        </div>
      </div>
    </section>

    <section class="panel">
      <div class="section-heading">
        <h2>DAB v2 Competitive Table</h2>
      </div>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>System</th>
              <th>Infra</th>
              <th>Retrieval</th>
              <th>Conversation</th>
              <th>Graph</th>
              <th>Intelligence</th>
              <th>Total</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Quaid</td>
              <td>{dabV2Systems.quaid?.sections?.s1_infrastructure?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.quaid?.sections?.s2_realworld_retrieval?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.quaid?.sections?.s3_conversation_memory?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.quaid?.sections?.s4_knowledge_graph?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.quaid?.sections?.s5_agent_intelligence?.score ?? 'n/a'}</td>
              <td>
                {dabV2Systems.quaid ? `${dabV2Systems.quaid.total}/${dabV2Systems.quaid.max} (${dabV2Systems.quaid.pct}%)` : 'n/a'}
              </td>
              <td><span class="pill is-warning">measured</span></td>
            </tr>
            <tr>
              <td>GBrain</td>
              <td>{dabV2Systems.gbrain?.sections?.s1_infrastructure?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.gbrain?.sections?.s2_realworld_retrieval?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.gbrain?.sections?.s3_conversation_memory?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.gbrain?.sections?.s4_knowledge_graph?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.gbrain?.sections?.s5_agent_intelligence?.score ?? 'n/a'}</td>
              <td>
                {dabV2Systems.gbrain ? `${dabV2Systems.gbrain.total}/${dabV2Systems.gbrain.max} (${dabV2Systems.gbrain.pct}%)` : 'n/a'}
              </td>
              <td><span class="pill is-alert">measured</span></td>
            </tr>
            <tr>
              <td>qmd</td>
              <td>{dabV2Systems.qmd?.sections?.s1_infrastructure?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.qmd?.sections?.s2_realworld_retrieval?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.qmd?.sections?.s3_conversation_memory?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.qmd?.sections?.s4_knowledge_graph?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.qmd?.sections?.s5_agent_intelligence?.score ?? 'n/a'}</td>
              <td>{dabV2Systems.qmd ? `${dabV2Systems.qmd.total}/${dabV2Systems.qmd.max} (${dabV2Systems.qmd.pct}%)` : 'n/a'}</td>
              <td><span class="pill is-alert">measured</span></td>
            </tr>
            <tr>
              <td>Mem0 v3</td>
              <td>~30</td>
              <td>~30</td>
              <td>~82</td>
              <td>0</td>
              <td>~10</td>
              <td>~152/420 (36%)</td>
              <td><span class="pill is-muted">estimated</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="note">Measured values come from published runs in this repo. Mem0 remains an estimate.</p>
    </section>

    {dabV2Quaid.length > 1 && (
      <section class="panel chart-card">
        <div class="chart-title">DAB v2 Quaid history</div>
        <canvas id="dab2History" height="110"></canvas>
      </section>
    )}

    {history.length > 0 && (
      <section class="panel">
        <div class="section-heading">
          <h2>DAB v1 Run History</h2>
        </div>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Version</th>
                <th>Date</th>
                <th>DAB %</th>
                <th>P@5</th>
                <th>R@5</th>
              </tr>
            </thead>
            <tbody>
              {history.slice().reverse().slice(0, 10).map((run) => (
                <tr>
                  <td>v{run.version}</td>
                  <td>{run.date}</td>
                  <td>{run.benchmarks?.dab?.pct != null ? `${run.benchmarks.dab.pct}%` : 'n/a'}</td>
                  <td>{run.benchmarks?.gbrain_evals?.p_at_5 != null ? `${run.benchmarks.gbrain_evals.p_at_5}%` : 'n/a'}</td>
                  <td>{run.benchmarks?.gbrain_evals?.r_at_5 != null ? `${run.benchmarks.gbrain_evals.r_at_5}%` : 'n/a'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}
  </div>

  <script define:vars={{ chartVersions, dabScores, rAt5Scores, p5Scores, dabV2Quaid }}>
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof Chart === 'undefined') return;

      const rootStyles = getComputedStyle(document.documentElement);
      const bronze = rootStyles.getPropertyValue('--q-bronze').trim();
      const bronzeSoft = rootStyles.getPropertyValue('--q-bronze-16').trim();
      const bone = rootStyles.getPropertyValue('--q-bone').trim();
      const muted = rootStyles.getPropertyValue('--q-muted').trim();
      const border = rootStyles.getPropertyValue('--q-bronze-12').trim();
      const success = rootStyles.getPropertyValue('--q-success').trim();
      const successSoft = rootStyles.getPropertyValue('--q-success-16').trim();
      const warning = rootStyles.getPropertyValue('--q-warning').trim();
      const warningSoft = rootStyles.getPropertyValue('--q-warning-16').trim();
      const fontUi = rootStyles.getPropertyValue('--font-ui').trim();

      const chartDefaults = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            labels: {
              color: bone,
              font: { family: fontUi, size: 11 },
            },
          },
        },
        scales: {
          x: {
            ticks: { color: muted, font: { family: fontUi, size: 10 } },
            grid: { color: border },
          },
          y: {
            ticks: { color: muted, font: { family: fontUi, size: 10 } },
            grid: { color: border },
          },
        },
      };

      const dabCtx = document.getElementById('dabHistory');
      if (dabCtx && dabScores.some((score) => score !== null)) {
        new Chart(dabCtx, {
          type: 'line',
          data: {
            labels: chartVersions,
            datasets: [{
              label: 'DAB %',
              data: dabScores,
              borderColor: bronze,
              backgroundColor: bronzeSoft,
              tension: 0.32,
              spanGaps: true,
              pointRadius: 3.5,
              fill: true,
            }],
          },
          options: {
            ...chartDefaults,
            scales: {
              ...chartDefaults.scales,
              y: {
                min: 0,
                max: 100,
                ticks: { color: muted, font: { family: fontUi, size: 10 } },
                grid: { color: border },
              },
            },
          },
        });
      }

      const msCtx = document.getElementById('msmarcoHistory');
      if (msCtx && (p5Scores.some((score) => score !== null) || rAt5Scores.some((score) => score !== null))) {
        new Chart(msCtx, {
          type: 'line',
          data: {
            labels: chartVersions,
            datasets: [
              {
                label: 'P@5 %',
                data: p5Scores,
                borderColor: bronze,
                backgroundColor: bronzeSoft,
                tension: 0.32,
                spanGaps: true,
                pointRadius: 3.5,
              },
              {
                label: 'R@5 %',
                data: rAt5Scores,
                borderColor: success,
                backgroundColor: successSoft,
                tension: 0.32,
                spanGaps: true,
                pointRadius: 3.5,
              },
            ],
          },
          options: {
            ...chartDefaults,
            scales: {
              ...chartDefaults.scales,
              y: {
                min: 0,
                max: 100,
                ticks: { color: muted, font: { family: fontUi, size: 10 } },
                grid: { color: border },
              },
            },
          },
        });
      }

      const dab2Ctx = document.getElementById('dab2History');
      if (dab2Ctx && dabV2Quaid.length > 1) {
        const labels = dabV2Quaid.map((run) => `v${run.version}`);
        const infraScores = dabV2Quaid.map((run) => run.sections?.s1_infrastructure?.score ?? null);
        const retrievalScores = dabV2Quaid.map((run) => run.sections?.s2_realworld_retrieval?.score ?? null);
        const totalScores = dabV2Quaid.map((run) => run.total ?? null);

        new Chart(dab2Ctx, {
          type: 'line',
          data: {
            labels,
            datasets: [
              {
                label: 'Infrastructure',
                data: infraScores,
                borderColor: success,
                backgroundColor: successSoft,
                tension: 0.32,
                spanGaps: true,
                pointRadius: 3.5,
                yAxisID: 'y1',
              },
              {
                label: 'Retrieval',
                data: retrievalScores,
                borderColor: bronze,
                backgroundColor: bronzeSoft,
                tension: 0.32,
                spanGaps: true,
                pointRadius: 3.5,
                yAxisID: 'y2',
              },
              {
                label: 'Total',
                data: totalScores,
                borderColor: warning,
                backgroundColor: warningSoft,
                tension: 0.32,
                spanGaps: true,
                pointRadius: 3.5,
                yAxisID: 'y3',
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                labels: {
                  color: bone,
                  font: { family: fontUi, size: 11 },
                },
              },
            },
            scales: {
              x: {
                ticks: { color: muted, font: { family: fontUi, size: 10 } },
                grid: { color: border },
              },
              y1: {
                type: 'linear',
                position: 'left',
                min: 0,
                max: 40,
                ticks: { color: muted, font: { family: fontUi, size: 10 } },
                grid: { color: border },
              },
              y2: {
                type: 'linear',
                position: 'right',
                min: 0,
                max: 100,
                ticks: { color: muted, font: { family: fontUi, size: 10 } },
                grid: { drawOnChartArea: false },
              },
              y3: {
                type: 'linear',
                position: 'right',
                min: 0,
                max: 400,
                ticks: { display: false },
                grid: { drawOnChartArea: false },
              },
            },
          },
        });
      }
    });
  </script>
</BaseLayout>
