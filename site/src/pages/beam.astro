---
import BaseLayout from '../layouts/BaseLayout.astro';
import reportData from '../data/report.json';

const beam = reportData.beam;
const mem0 = reportData.reference?.mem0_v3?.beam ?? {};

const formatPercent = (value) => {
  if (value == null) return 'pending';
  if (typeof value === 'string') return value;
  return `${value.toFixed(Number.isInteger(value) ? 0 : 1)}%`;
};

const currentScores = beam?.scores ?? {};
const currentStatus = beam?.status ?? 'pending';
const currentVersion = beam?.version ? `v${beam.version}` : 'No Quaid run yet';
const currentDate = beam?.date ?? 'Waiting for results/beam-*.json';
const statusTone = currentStatus === 'measured' ? 'is-success' : 'is-warning';
---

<BaseLayout
  title="BEAM | Quaid Evals"
  description="BEAM is the extreme-scale memory benchmark where context stuffing is physically impossible."
>
  <div class="page">
    <section class="hero">
      <div class="page-kicker">Industry Benchmark</div>
      <h1>BEAM</h1>
      <p>Extreme-scale memory benchmark. Context stuffing is physically impossible.</p>
    </section>

    <section class="panel">
      <div class="section-heading">
        <h2>What BEAM Is</h2>
      </div>
      <p>BEAM evaluates memory systems at 100K, 1M, and 10M token corpus sizes.</p>
      <p>
        At 10M tokens, you cannot fit the corpus into any model context window. Only real memory architectures
        survive. That is why BEAM matters more than prompt engineering demos.
      </p>
    </section>

    <section class="panel">
      <div class="section-heading">
        <h2>Reference Scores</h2>
      </div>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>System</th>
              <th>BEAM 1M</th>
              <th>BEAM 10M</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Mem0 v3</td>
              <td>{formatPercent(mem0.score_1m)}</td>
              <td>{formatPercent(mem0.score_10m)}</td>
            </tr>
            <tr>
              <td>Hindsight</td>
              <td>TBD</td>
              <td>SOTA</td>
            </tr>
            <tr>
              <td>Quaid</td>
              <td>{currentStatus === 'measured' ? formatPercent(currentScores.score_1m) : 'pending'}</td>
              <td>{currentStatus === 'measured' ? formatPercent(currentScores.score_10m) : 'pending'}</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="note">Reference values come from published materials. Quaid remains unmeasured until results land in this repo.</p>
    </section>

    <section class="panel">
      <div class="section-heading">
        <h2>Status</h2>
      </div>
      <p>BEAM corpus released by Mem0. Scaffold ready, CI support in place, runs pending OPENAI_API_KEY in CI secrets.</p>
      <div class={`pill ${statusTone}`}>{currentStatus}</div>
      <div class="metric-sub">{currentVersion}</div>
      <div class="metric-sub">{currentDate}</div>
    </section>

    <section class="panel">
      <div class="section-heading">
        <h2>How To Run</h2>
      </div>
      <pre class="mono-run"><code>OPENAI_API_KEY=sk-... bash benchmarks/beam/run.sh</code></pre>
    </section>
  </div>
</BaseLayout>
