---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'benchmark.quaid.app results and methodology.' } = Astro.props;

const pathname = Astro.url.pathname.length > 1
  ? Astro.url.pathname.replace(/\/$/, '')
  : Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Results' },
  { href: '/dab-v1', label: 'DAB v1' },
  { href: '/dab-v2', label: 'DAB v2' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
    <style is:global>
      :root {
        --q-ink: #0d0d0d;
        --q-charcoal: #161616;
        --q-stone: #2a2a2a;
        --q-bone: #f7f7f5;
        --q-linen: #d6d0c4;
        --q-bronze: #a59a7a;
        --q-muted: #8a8376;
        --font-display: "Cormorant Garamond", Georgia, serif;
        --font-ui: Inter, system-ui, sans-serif;
        --font-mono: "JetBrains Mono", Consolas, monospace;
        --q-border: 1px solid rgba(165, 154, 122, 0.18);
        --q-card-radius: 8px;
        --q-page-width: 1160px;
        --q-nav-bg: rgba(22, 22, 22, 0.94);
        --q-bronze-08: rgba(165, 154, 122, 0.08);
        --q-bronze-12: rgba(165, 154, 122, 0.12);
        --q-bronze-16: rgba(165, 154, 122, 0.16);
        --q-bronze-22: rgba(165, 154, 122, 0.22);
        --q-bone-08: rgba(247, 247, 245, 0.08);
        --q-bone-12: rgba(247, 247, 245, 0.12);
        --q-shadow: rgba(13, 13, 13, 0.26);
        --q-bronze-haze: rgba(165, 154, 122, 0.14);
        --q-success: #9eb37a;
        --q-success-16: rgba(158, 179, 122, 0.16);
        --q-warning: #c7ae69;
        --q-warning-16: rgba(199, 174, 105, 0.16);
        --q-alert: #bb8176;
        --q-alert-16: rgba(187, 129, 118, 0.16);
        --q-grid-gap: 1.25rem;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-ui);
        color: var(--q-linen);
        background-color: var(--q-ink);
        background-image:
          radial-gradient(circle at top, var(--q-bronze-haze), transparent 34%),
          linear-gradient(180deg, var(--q-charcoal) 0%, var(--q-ink) 40%);
        line-height: 1.6;
      }

      a {
        color: inherit;
      }

      img,
      canvas {
        display: block;
        max-width: 100%;
      }

      h1,
      h2,
      h3,
      h4,
      p,
      ul,
      ol {
        margin: 0;
      }

      code,
      pre,
      kbd {
        font-family: var(--font-mono);
      }

      .site-nav {
        position: sticky;
        top: 0;
        z-index: 40;
        background: var(--q-nav-bg);
        border-bottom: var(--q-border);
        backdrop-filter: blur(18px);
      }

      .site-nav__inner,
      .site-footer__inner {
        max-width: var(--q-page-width);
        margin: 0 auto;
        padding-inline: 1.5rem;
      }

      .site-nav__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding-block: 0.95rem;
      }

      .site-wordmark {
        color: var(--q-bronze);
        font-family: var(--font-display);
        font-size: clamp(1.85rem, 2.8vw, 2.3rem);
        letter-spacing: 0.02em;
        text-decoration: none;
        text-transform: lowercase;
        white-space: nowrap;
      }

      .site-links {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.55rem 1.25rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .site-links a {
        color: var(--q-muted);
        font-size: 0.95rem;
        font-weight: 500;
        text-decoration: none;
        transition: color 160ms ease;
      }

      .site-links a:hover,
      .site-links a[aria-current='page'] {
        color: var(--q-bone);
      }

      main {
        max-width: var(--q-page-width);
        margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
      }

      .page {
        display: grid;
        gap: 2rem;
      }

      .hero {
        display: grid;
        gap: 0.9rem;
        padding-top: 0.25rem;
      }

      .page-kicker {
        color: var(--q-bronze);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .hero h1 {
        color: var(--q-bone);
        font-family: var(--font-display);
        font-size: clamp(3rem, 7vw, 5.2rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 0.96;
      }

      .hero p {
        max-width: 56rem;
        color: var(--q-linen);
        font-size: 1.05rem;
      }

      .section-heading {
        display: grid;
        gap: 0.35rem;
      }

      .section-heading h2 {
        color: var(--q-bone);
        font-size: clamp(1.45rem, 3vw, 2rem);
        font-weight: 600;
      }

      .section-heading p {
        color: var(--q-muted);
        max-width: 52rem;
      }

      .panel {
        display: grid;
        gap: 1rem;
        padding: 1.35rem;
        background: var(--q-stone);
        border: var(--q-border);
        border-radius: var(--q-card-radius);
        box-shadow: 0 20px 40px var(--q-shadow);
      }

      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--q-grid-gap);
      }

      .three-up {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: var(--q-grid-gap);
      }

      .split-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--q-grid-gap);
      }

      .metric-card {
        display: grid;
        gap: 0.45rem;
      }

      .metric-label {
        color: var(--q-muted);
        font-size: 0.76rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .metric-value {
        color: var(--q-bone);
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        font-weight: 700;
        line-height: 1;
      }

      .metric-sub {
        color: var(--q-muted);
        font-size: 0.88rem;
      }

      .metric-value.is-bronze {
        color: var(--q-bronze);
      }

      .metric-value.is-success {
        color: var(--q-success);
      }

      .metric-value.is-warning {
        color: var(--q-warning);
      }

      .metric-value.is-alert {
        color: var(--q-alert);
      }

      .chart-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--q-grid-gap);
      }

      .chart-card {
        display: grid;
        gap: 1rem;
      }

      .chart-title {
        color: var(--q-bronze);
        font-size: 0.86rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .table-wrap {
        overflow-x: auto;
      }

      .data-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 640px;
      }

      .data-table th,
      .data-table td {
        padding: 0.85rem 0.75rem;
        border-bottom: var(--q-border);
        text-align: left;
        vertical-align: top;
      }

      .data-table th {
        color: var(--q-muted);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .data-table tbody tr:hover td {
        background: var(--q-bronze-08);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.22rem 0.6rem;
        border: var(--q-border);
        border-radius: 999px;
        background: var(--q-bronze-08);
        color: var(--q-bone);
        font-size: 0.75rem;
        font-weight: 600;
        line-height: 1;
        white-space: nowrap;
      }

      .pill.is-muted {
        color: var(--q-muted);
      }

      .pill.is-success {
        background: var(--q-success-16);
        color: var(--q-success);
      }

      .pill.is-warning {
        background: var(--q-warning-16);
        color: var(--q-warning);
      }

      .pill.is-alert {
        background: var(--q-alert-16);
        color: var(--q-alert);
      }

      .mono-run {
        display: block;
        padding: 0.9rem 1rem;
        background: var(--q-ink);
        border: var(--q-border);
        border-radius: var(--q-card-radius);
        color: var(--q-bone);
        font-size: 0.94rem;
        overflow-x: auto;
        white-space: pre-wrap;
      }

      .content-list {
        display: grid;
        gap: 0.75rem;
        padding-left: 1.1rem;
      }

      .content-list li {
        color: var(--q-linen);
      }

      .note {
        color: var(--q-muted);
        font-size: 0.86rem;
      }

      .callout {
        display: grid;
        gap: 0.55rem;
        padding: 1rem 1.1rem;
        background: var(--q-bronze-08);
        border: var(--q-border);
        border-radius: var(--q-card-radius);
      }

      .callout.is-alert {
        background: var(--q-alert-16);
      }

      .callout strong {
        color: var(--q-bone);
      }

      .inline-link {
        color: var(--q-bronze);
        text-decoration: none;
      }

      .inline-link:hover {
        color: var(--q-bone);
      }

      .site-footer {
        border-top: var(--q-border);
      }

      .site-footer__inner {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        padding-block: 1.4rem 2rem;
        color: var(--q-muted);
        font-size: 0.9rem;
      }

      @media (max-width: 900px) {
        .three-up,
        .split-grid,
        .chart-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .site-nav__inner {
          align-items: flex-start;
          flex-direction: column;
        }

        main {
          padding-inline: 1rem;
        }

        .site-nav__inner,
        .site-footer__inner {
          padding-inline: 1rem;
        }

        .panel {
          padding: 1.1rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-nav">
      <div class="site-nav__inner">
        <a class="site-wordmark" href="/">quaid evals</a>
        <nav aria-label="Primary">
          <ul class="site-links">
            {navLinks.map((link) => (
              <li>
                <a href={link.href} aria-current={pathname === link.href ? 'page' : undefined}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <a class="inline-link" href="https://benchmark.quaid.app">benchmark.quaid.app</a>
        <span>·</span>
        <a class="inline-link" href="https://github.com/quaid-app/quaid-evals">quaid-app/quaid-evals</a>
        <span>·</span>
        <span>persistent memory for agents</span>
      </div>
    </footer>
  </body>
</html>
